{
  "manifest_version": 3,
  "name": "Flip Meet",
  "version": "1.3.7",
  "description": "Slash commands for chat: /meet, /time, /poll, /help and more.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["scripting", "storage"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://staging.flipnext.de/*",
    "https://show.flipnext.de/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://staging.flipnext.de/chats/*",
        "https://show.flipnext.de/chats/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
