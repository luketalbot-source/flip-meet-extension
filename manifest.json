{
  "manifest_version": 3,
  "name": "Flip Meet",
  "version": "1.0.1",
  "description": "Type /meet in a Flip chat to drop in an instant Google Meet link.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": [
    "https://meet.google.com/*",
    "https://staging.flipnext.de/*",
    "https://show.flipnext.de/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://staging.flipnext.de/chats/*",
        "https://show.flipnext.de/chats/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
