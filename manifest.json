{
  "manifest_version": 3,
  "name": "Flip Meet",
  "version": "0.2.0",
  "description": "Type /meet in a Flip chat to drop in an instant Google Meet link.",
  "host_permissions": [
    "https://meet.google.com/*",
    "https://staging.flipnext.de/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://staging.flipnext.de/chats/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
